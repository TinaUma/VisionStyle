ANTHROPIC_API_KEY=your_anthropic_key_here

# Провайдер: anthropic | openai | groq | together (по умолчанию: anthropic)
VISION_PROVIDER=anthropic

# Модель (опционально, есть дефолты для каждого провайдера)
# VISION_MODEL=claude-sonnet-4-5

# Ключи для OpenAI-совместимых провайдеров (нужен только нужный)
# OPENAI_API_KEY=your_openai_key
# GROQ_API_KEY=your_groq_key
# TOGETHER_API_KEY=your_together_key

# URL для кастомного OpenAI-совместимого эндпоинта (опционально)
# OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1
